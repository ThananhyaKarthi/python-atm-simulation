print('Welcome to ATM')

balance = 10000

def chkbalance(balance):
    print('Your bank balance is:', balance)

def deposit(balance):
    dep = int(input('Enter amount to be deposited: '))
    balance += dep
    print('Amount has been deposited successfully')
    print('Updated balance is', balance)
    return balance

def withdraw(balance):
    amt = int(input('Enter amount to be withdrawn: '))
    if amt > balance:
        print('Insufficient balance')
        return balance
    else:
        balance -= amt
        print('Updated balance is', balance)
        print('Please collect the cash at counter')
        return balance

while True:
    print('For checking balance enter 1')
    print('For Deposit enter 2')
    print('For Withdrawal enter 3')
    print('For exiting enter 4')

    ch = int(input('Enter choice: '))

    if ch == 1:
        chkbalance(balance)
    elif ch == 2:
        balance = deposit(balance)
    elif ch == 3:
        balance = withdraw(balance)
    elif ch == 4:
        print('Thank you for using the ATM, Visit again')
        break
    else:
        print('Enter valid number')
